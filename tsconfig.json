{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "src/*": ["react/*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "react/**/*.ts"
, "react/utilities/formatters/bytesToSize.tsx", "react/utilities/formatters/Fdate.tsx", "react/utilities/formatters/Fmoney.tsx", "react/utilities/formatters/Fphone.tsx", "react/utilities/formatters/timeAgo.tsx", "react/utilities/validators/Vcard.tsx", "react/utilities/Print-pdf.tsx", "react/utilities/network-status.tsx", "react/utilities/Image-Compressor.tsx", "react/utilities/Export-Excel.tsx", "react/utilities/Device-info.tsx"  ],
  "exclude": [
    "node_modules"
  ]
}
