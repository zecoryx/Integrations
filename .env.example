# Server Configuration
PORT=3000
NODE_ENV=development

# Core API
API_URL=http://localhost:3000

# AI Services (Server-side)
OPENAI_API_KEY=your_openai_api_key
CLAUDE_API_KEY=your_claude_api_key
GEMINI_API_KEY=your_gemini_api_key

# Firebase (Client-side)
FIREBASE_CLIENT_API_KEY=your_firebase_api_key
FIREBASE_CLIENT_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_CLIENT_PROJECT_ID=your_project_id
FIREBASE_CLIENT_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_CLIENT_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_CLIENT_APP_ID=your_app_id
FIREBASE_CLIENT_MEASUREMENT_ID=your_measurement_id
FIREBASE_CLIENT_VAPID_KEY=your_vapid_key

# OAuth2 (Client-side)
GOOGLE_CLIENT_ID=your_google_client_id
GITHUB_CLIENT_ID=your_github_client_id
REDIRECT_URI=http://localhost:3000/auth/callback

# OneID (Uzbekistan)
ONEID_CLIENT_ID=your_oneid_client_id
ONEID_CLIENT_SECRET=your_oneid_client_secret
ONEID_REDIRECT_URI=http://localhost:3000/auth/oneid/callback

# Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key
YANDEX_MAPS_API_KEY=your_yandex_maps_key

# Payments - CLICK
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SERVICE_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret_key
CLICK_API_URL=https://api.click.uz/v2/

# Payments - PAYME
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret_key
PAYME_CALLBACK_URL=http://localhost:3000/payments/payme/callback

# Payments - UZUM
UZUM_CLIENT_ID=your_uzum_client_id
UZUM_CLIENT_SECRET=your_uzum_client_secret
UZUM_RETURN_URL=http://localhost:3000/payments/uzum/return
UZUM_API_URL=https://api.uzum.uz/

# Payments - PAYNET
PAYNET_MERCHANT_ID=your_paynet_merchant_id
PAYNET_USERNAME=your_paynet_username
PAYNET_PASSWORD=your_paynet_password
PAYNET_API_URL=https://api.paynet.uz/

# Payments - PAYPAL
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CURRENCY=USD

# Payments - STRIPE
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Other Services
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
ESKIZ_SMS_CLIENT_EMAIL=your_eskiz_email
ESKIZ_SMS_CLIENT_PASSWORD=your_eskiz_password
ESKIZ_SMS_API_URL=https://notify.eskiz.uz/api/
TELEGRAM_BOT_NAME=your_bot_name
TELEGRAM_BOT_TOKEN=your_bot_token

# Realtime
SOCKET_URL=http://localhost:3001
