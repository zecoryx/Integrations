# =====================================================
# FRONTEND INTEGRATIONS — .env misol fayli
# Faqat ishlatmoqchi bo'lgan integratsiyalar uchun
# tegishli qiymatlarni to'ldiring.
# =====================================================

# Umumiy
API_URL=http://localhost:3000
NODE_ENV=development
DATABASE_URL=your_mongodb_connection_string

# ─────────────────────────────
# AI Integratsiyalar
# ─────────────────────────────
OPENAI_API_KEY=your_openai_api_key
CLAUDE_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_google_gemini_api_key

# ─────────────────────────────
# Auth — Firebase (Google Login)
# console.firebase.google.com dan oling
# ─────────────────────────────
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ─────────────────────────────
# Auth — OAuth2 (Google & GitHub)
# Google: console.cloud.google.com
# GitHub: github.com/settings/developers
# ─────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GITHUB_CLIENT_ID=your_github_client_id
REDIRECT_URI=http://localhost:3000/auth/callback

# ─────────────────────────────
# Auth — OneID (egov.uz)
# my.gov.uz developer portalida ro'yxatdan o'ting
# ─────────────────────────────
ONEID_CLIENT_ID=your_oneid_client_id
ONEID_CLIENT_SECRET=your_oneid_client_secret
ONEID_REDIRECT_URI=http://localhost:3000/auth/oneid/callback

# ─────────────────────────────
# Auth — SMS OTP
# Backend endpointi: /send-otp va /verify-otp
# ─────────────────────────────
SMS_AUTH_API_URL=http://localhost:3000/api/auth

# ─────────────────────────────
# Xaritalar
# ─────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
YANDEX_MAPS_API_KEY=your_yandex_maps_api_key

# ─────────────────────────────
# To'lov — Click
# merchant.click.uz dan oling
# ─────────────────────────────
CLICK_SECRET=your_click_secret_key
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_API_URL=https://my.click.uz/services/pay

# ─────────────────────────────
# To'lov — Payme
# merchant.payme.uz dan oling
# ─────────────────────────────
PAYME_LOGIN=payme
PAYME_MERCHANT_KEY=your_payme_merchant_key
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_CALLBACK_URL=http://localhost:3000/payment/success

# ─────────────────────────────
# To'lov — Uzum Bank
# business.uzum.uz dan oling
# ─────────────────────────────
UZUM_SERVICE_ID=your_uzum_service_id
UZUM_LOGIN=your_uzum_login
UZUM_PASSWORD=your_uzum_password
UZUM_CLIENT_ID=your_uzum_client_id
UZUM_CLIENT_SECRET=your_uzum_client_secret
UZUM_RETURN_URL=http://localhost:3000/payment/success
UZUM_API_URL=https://api.uzum.uz

# ─────────────────────────────
# To'lov — Paynet
# paynet.uz merchant kabinetidan oling
# ─────────────────────────────
PAYNET_MERCHANT_ID=your_paynet_merchant_id
PAYNET_USERNAME=your_paynet_username
PAYNET_PASSWORD=your_paynet_password
PAYNET_API_URL=your_paynet_api_url

# ─────────────────────────────
# To'lov — PayPal
# developer.paypal.com dan oling
# ─────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CURRENCY=USD

# ─────────────────────────────
# To'lov — Crypto (WalletConnect)
# cloud.walletconnect.com dan oling
# ─────────────────────────────
WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id

# ─────────────────────────────
# Xavfsizlik — reCAPTCHA v3
# google.com/recaptcha/admin dan oling
# ─────────────────────────────
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ─────────────────────────────
# Bildirishnomalar — Email
# Backend endpointi: /send
# ─────────────────────────────
EMAIL_SERVICE_API_URL=http://localhost:3000/api/email

# ─────────────────────────────
# Bildirishnomalar — Eskiz.uz SMS
# eskiz.uz dashboard dan oling
# ─────────────────────────────
ESKIZ_SMS_API_URL=http://localhost:3000/api/sms

# ─────────────────────────────
# Bildirishnomalar — Firebase FCM (Push)
# console.firebase.google.com → Cloud Messaging
# ─────────────────────────────
PUSH_NOTIFICATION_API_URL=http://localhost:3000/api/push
FIREBASE_CLIENT_API_KEY=your_firebase_client_api_key
FIREBASE_CLIENT_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_CLIENT_PROJECT_ID=your_project_id
FIREBASE_CLIENT_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_CLIENT_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_CLIENT_APP_ID=your_firebase_client_app_id
FIREBASE_CLIENT_MEASUREMENT_ID=your_measurement_id
FIREBASE_CLIENT_VAPID_KEY=your_vapid_key

# ─────────────────────────────
# Auth — Telegram Login
# t.me/BotFather dan bot yarating
# ─────────────────────────────
TELEGRAM_BOT_NAME=your_bot_username
TELEGRAM_BOT_TOKEN=your_bot_token

# ─────────────────────────────
# To'lov — Stripe
# dashboard.stripe.com/apikeys dan oling
# ─────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# ─────────────────────────────
# Analitika — Google Analytics 4
# analytics.google.com dan Measurement ID oling
# ─────────────────────────────
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ─────────────────────────────
# Analitika — Yandex Metrika
# metrika.yandex.com dan schyotchik ID oling
# ─────────────────────────────
YANDEX_METRIKA_ID=12345678

# ─────────────────────────────
# Real-vaqt — Socket.IO
# Backend server manzili
# ─────────────────────────────
SOCKET_URL=http://localhost:3001
